# ─── Public site ──────────────────────────────────────────────
# Canonical URL of your deployed site (used for metadata/OpenGraph)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Supabase (optional — see README "Switch to Supabase") ───
# Leave blank to run on the built-in mock JSON store.
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Admin auth (mock cookie auth) ────────────────────────────
# Credentials used by the /admin/login page. Change before deploy.
ADMIN_EMAIL=admin@portfolio.local
ADMIN_PASSWORD=admin123
# Secret used to sign the session cookie. Set a long random string in prod.
AUTH_SECRET=dev-only-insecure-secret-change-me
